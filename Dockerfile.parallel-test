# Fast test Dockerfile for parallel TEE deployment.
#
# Difference from Dockerfile.production:
#   - NO Rust build stage (saves ~10 minutes of rebuild time).
#   - snpguest is copied from ./third_party/snpguest on the build host.
#   - Operator must extract snpguest from an existing TS enclave container
#     before building:
#
#       mkdir -p third_party
#       docker cp enclave_service:/usr/bin/snpguest ./third_party/snpguest
#       chmod +x ./third_party/snpguest
#
# NOTE: we use ./third_party/ rather than ./bin/ because .dockerignore
# excludes bin/ to keep the image clean of local build artefacts.
#
# This dockerfile is ONLY intended for the parallel test stack
# (docker-compose.parallel-test.yml). Production deployments must continue
# to use Dockerfile.production which builds snpguest from source.

# Go build stage
# VULN-001: pin to 1.26.2-alpine so the stdlib CVEs fixed in 1.26.1/1.26.2
# are picked up deterministically (floating `1.26-alpine` resolved to
# 1.26.0 at audit time).
FROM golang:1.26.2-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git ca-certificates tzdata

COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download

COPY . .

# BuildKit cache mounts make incremental rebuilds ~5× faster by reusing
# the Go build cache (/root/.cache/go-build) and module cache between runs.
# Requires DOCKER_BUILDKIT=1 (default on recent Docker / buildx).
RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg/mod \
    CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -trimpath \
    -ldflags="-w -s" \
    -o /enclave \
    ./cmd/enclave

RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg/mod \
    CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -trimpath \
    -ldflags="-w -s" \
    -o /admin-update-creds \
    ./cmd/admin-update-creds

RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg/mod \
    CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -trimpath \
    -ldflags="-w -s" \
    -o /admin-probe \
    ./cmd/admin-probe

# Runtime stage
FROM alpine:3.20

WORKDIR /app

RUN apk add --no-cache ca-certificates tzdata wget

# Copy prebuilt snpguest from the host (must be placed in
# ./third_party/snpguest before `docker compose build` is invoked).
COPY third_party/snpguest /usr/local/bin/snpguest
RUN chmod +x /usr/local/bin/snpguest

# Copy Go binary
COPY --from=builder /enclave /app/enclave
COPY --from=builder /admin-update-creds /app/admin-update-creds
COPY --from=builder /admin-probe /app/admin-probe

# Copy migrations
COPY --from=builder /app/migrations /app/migrations

# Cache directory for VCEK certs (runs as root for /dev/sev-guest access).
RUN mkdir -p /var/cache/enclave/certs

EXPOSE 3060 50061 50062 9093

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-check-certificate -qO/dev/null https://localhost:3060/health || exit 1

ENTRYPOINT ["/app/enclave"]
