# ============================================
# Enclave Go — Development Environment
# ============================================
# Configuration optimisée pour le développement local

# --- Core ---
ENV=development
DATABASE_URL=postgres://enclave:enclave@enclave-go-db:5432/enclave_go?sslmode=disable

# --- Encryption ---
# Clé fixe pour dev (JAMAIS en production!)
# Permet de garder les données entre redémarrages
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Ports ---
GRPC_PORT=50051
REST_PORT=8080
LOG_STREAM_PORT=50052
METRICS_PORT=9090

# --- gRPC ---
GRPC_INSECURE=true    # Pas de TLS en dev pour simplifier

# --- Logging ---
LOG_LEVEL=debug       # Logs verbeux pour debugging

# --- Metrics ---
METRICS_ENABLED=true

# --- CORS ---
CORS_ORIGIN=*         # CORS ouvert en dev (JAMAIS en prod!)

# --- HTTP Proxy (désactivé en dev) ---
# EXCHANGE_HTTP_PROXY=
PROXY_EXCHANGES=

# --- Benchmark Service (local ou mock) ---
# BENCHMARK_SERVICE_URL=http://localhost:3000

# --- Data Retention ---
DATA_RETENTION_DAYS=30

# --- Feature Toggles ---
ENABLE_DAILY_SYNC=true

# --- Log Stream Auth (désactivé en dev) ---
# LOG_STREAM_API_KEY=
